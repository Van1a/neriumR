local function cloneLabel(template, text, parent, color)
	local obj = template:Clone()
	obj.Visible = true
	obj.Text = tostring(text)

	if color then
		obj.TextColor3 = color
	end

	obj.Parent = parent
	return obj
end

local function terminalPrint(text)
	cloneLabel(templates.Output, text, terminalInput)
end

local function terminalWarn(text)
	cloneLabel(templates.Warning, text, terminalInput)
end

local function terminalError(text)
	cloneLabel(templates.Error, text, terminalInput)
end

local function consolePrint(text)
	cloneLabel(templates.Output, text, consoleLog)
end

local function consoleWarn(text)
	cloneLabel(templates.Warning, text, consoleLog)
end

local function consoleError(text)
	cloneLabel(templates.Error, text, consoleLog)
end

local function tween(object, info, properties)
	local t = TweenService:Create(object, info, properties)
	t:Play()
	return t
end

local function animateOpen(frame, default)
	frame.Visible = true
	frame.Size = UDim2.new(0, 0, 0, 0)
	frame.Position = default.position
	frame.BackgroundTransparency = 1

	tween(frame, tweens.maximize, {
		Size = default.size,
		Position = default.position,
		BackgroundTransparency = 0
	})
end

local function animateClose(frame, default)
	local t = tween(frame, tweens.maximize, {
		Size = UDim2.new(0, 0, 0, 0),
		BackgroundTransparency = 1
	})

	t.Completed:Once(function()
		frame.Visible = false
		frame.Size = default.size
		frame.Position = default.position
	end)
end

local function toggleWindow(frame, default)
	if frame.Visible then
		animateClose(frame, default)
	else
		animateOpen(frame, default)
	end
end

buttons.Minimize.MouseButton1Click:Connect(function()
	if state.minimized then return end
	state.minimized = true

	state.preMinimize = {
		position = body.Position,
		size = body.Size,
		maximized = state.maximized
	}

	state.maximized = false

	local t = tween(body, tweens.minimize, {
		Position = terminalToggle.Position,
		Size = terminalToggle.Size
	})

	t.Completed:Once(function()
		body.Visible = false
		terminalToggle.Visible = true
	end)
end)

terminalToggle.terminalIcon.MouseButton1Click:Connect(function()
	if not state.minimized then return end
	if not state.preMinimize then return end

	state.minimized = false

	terminalToggle.Visible = false
	body.Visible = true

	body.Position = terminalToggle.Position
	body.Size = terminalToggle.Size

	local t = tween(body, tweens.minimize, {
		Position = state.preMinimize.position,
		Size = state.preMinimize.size
	})

	state.maximized = state.preMinimize.maximized
end)

buttons.Close.MouseButton1Click:Connect(function()
	local t = tween(body, tweens.close, {
		Size = UDim2.new(0, 0, 0, 0),
		BackgroundTransparency = 1
	})

	t.Completed:Once(function()
		terminal:Destroy()
	end)
end)

local restoreState = {
	position = body.Position,
	size = body.Size
}

buttons.Fullscreen.MouseButton1Click:Connect(function()
	if state.minimized then
		return
	end

	if not state.maximized then
		restoreState.position = body.Position
		restoreState.size = body.Size
	end

	state.maximized = not state.maximized

	tween(body, tweens.maximize, {
		Position = state.maximized
			and UDim2.new(0.5, 0, 0.5, 0)
			or restoreState.position,

		Size = state.maximized
			and UDim2.new(0.95, 0, 0.95, 0)
			or restoreState.size
	})
end)

