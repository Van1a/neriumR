local commands = {}

local function registerCommand(name, callback)
	commands[name:lower()] = callback
end

registerCommand("help", function()
    local helpText = [[
		Available Built‑In Commands:

		[ code ]         → Opens the code editor
		[ run code ]     → Executes the code from the editor
		[ console ]      → Opens the console
		[ clearconsole ] → Clears all console text
		[ clear ]        → Clears all terminal text
		]]

			terminalWarn("Available commands:")
			terminalPrint(helpText)
	end)


registerCommand("console", function()
	toggleWindow(console, defaults.console)
end)

registerCommand("code", function()
	if not console.Visible then
		animateOpen(console, defaults.console)
	end

	toggleWindow(codeEditor, defaults.codeEditor)
end)

registerCommand("run code", function()
	local source = codeInput.Text

	if source:gsub("%s+", "") == "" then
		terminalWarn("No code to run")
		return
	end

	if not console.Visible then
		animateOpen(console, defaults.console)
	end
	local fn, compileError = loadstring(source)

	if not fn then
		consoleError(tostring(compileError))
		return
	end

	local success, runtimeError = pcall(fn)

	if not success then
		consoleError(tostring(runtimeError))
		return
	end

	terminalPrint("Code ran successfully")
end)

registerCommand("clear", function()
	for _, child in ipairs(terminalInput:GetChildren()) do
		if child:IsA("TextLabel") then
			child:Destroy()
		end
	end
end)

registerCommand("consoleclear", function()
	for _, child in ipairs(consoleLog:GetChildren()) do
		if child:IsA("TextLabel") then
			child:Destroy()
		end
	end
end)

inputBox.FocusLost:Connect(function(enterPressed)
	if not enterPressed then
		return
	end

	local raw = inputBox.Text
	local command = raw:lower():match("^%s*(.-)%s*$")

	terminalPrint("C:/USER> " .. raw)

	local callback = commands[command]

	if callback then
		callback(raw, command)
	elseif command ~= "" then
		terminalError("'" .. raw .. "' is not recognized as a command.")
	end

	inputBox.Text = ""

	task.defer(function()
		inputBox:CaptureFocus()
	end)
end)

local function setupDragging(frame)
	local drag = frame:FindFirstChildWhichIsA("UIDragDetector")
	if not drag then return end

	local scale = frame:FindFirstChildOfClass("UIScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Scale = 1
		scale.Parent = frame
	end

	drag.DragStart:Connect(function()
		tween(scale, tweens.drag, { Scale = 0.97 })
		tween(frame, tweens.drag, {
			Rotation = 4,
			BackgroundTransparency = 0.3
		})
	end)

	drag.DragEnd:Connect(function()
		tween(scale, tweens.drag, { Scale = 1 })
		tween(frame, tweens.drag, {
			Rotation = 0,
			BackgroundTransparency = 0
		})
	end)
end

