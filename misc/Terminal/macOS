local function stringify(...)
	local packed = table.pack(...)
	local out = {}

	for i = 1, packed.n do
		out[i] = tostring(packed[i])
	end

	return table.concat(out, " ")
end
local oldPrint
oldPrint = hookfunction(env.print, function(...)
	consolePrint(stringify(...))
	return oldPrint(...)
end)

local oldWarn
oldWarn = hookfunction(env.warn, function(...)
	consoleWarn(stringify(...))
	return oldWarn(...)
end)

local oldError = env.error
oldError = hookfunction(env.error, function(message, level)
	consoleError(tostring(message))
	return oldError(message, level)
end)

return {
	print = function(self, text)
		terminalPrint(text)
	end,

	warn = function(self, text)
		terminalWarn(text)
	end,

	error = function(self, text)
		terminalError(text)
	end,

	consolePrint = function(self, text)
		consolePrint(text)
	end,

	consoleWarn = function(self, text)
		consoleWarn(text)
	end,

	consoleError = function(self, text)
		consoleError(text)
	end,

	register = function(self, cmd, callback)
		registerCommand(cmd, callback)
	end
}
